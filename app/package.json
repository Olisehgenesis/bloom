    "@tanstack/react-query": "^5.100.10",
    "@uniswap/sdk-core": "^7.14.0",
    "@uniswap/v3-sdk": "^3.30.0",
    "crypto-js": "^4.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "viem": "^2.49.3",
    "wagmi": "^3.6.15"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/crypto-js": "^4.1.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
